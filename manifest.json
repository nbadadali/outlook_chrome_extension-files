{
  "manifest_version": 3,
  "name": "Sa.AI for Outlook",
  "version": "2.2.3",
  "description": "AI-powered Inbox assistant. Summarize emails, extract tasks, chat with AI, and manage your inbox workflow efficiently.",
  "author": "Sa.AI Team",
  "homepage_url": "https://saai.dev",
  
  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "tabs",
    "scripting",
    "alarms"
  ],

  "host_permissions": [
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "https://outlook.com/*",
    "https://login.microsoftonline.com/*",
    "https://graph.microsoft.com/*",
    "https://connector.saai.dev/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.com/*"
      ],
      "js": ["content-outlook.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sa.AI - AI Inbox Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  
  "minimum_chrome_version": "88",
  "short_name": "Sa.AI",
  
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.com/*"
      ]
    }
  ],
  
  "externally_connectable": {
    "matches": [
      "https://connector.saai.dev/*"
    ]
  }
}
